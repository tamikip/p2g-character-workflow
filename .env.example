# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_SIZE_BYTES=10485760
MIN_IMAGE_WIDTH=256
MIN_IMAGE_HEIGHT=256

# Pipeline mode: mock | live
PIPELINE_MODE=mock

# Providers
BG_REMOVAL_PROVIDER=mock
EXPRESSION_PROVIDER=mock
CG_PROVIDER=mock

# Banana2 live provider
BANANA2_API_KEY=
BANANA2_BASE_URL=https://api.apiyi.com
BANANA2_MODEL=gemini-3.1-flash-image-preview
BANANA2_IMAGE_SIZE=1K
BANANA2_ASPECT_RATIO=1:1
BANANA2_TIMEOUT_MS=120000

# Storage
UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs

# Example live mode:
# PIPELINE_MODE=live
# BG_REMOVAL_PROVIDER=banana2
# EXPRESSION_PROVIDER=banana2
# CG_PROVIDER=banana2
