# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
MAX_UPLOAD_SIZE_BYTES=10485760
MIN_IMAGE_WIDTH=256
MIN_IMAGE_HEIGHT=256

# Pipeline mode: mock | live
PIPELINE_MODE=mock

# Providers (for future integration)
BG_REMOVAL_PROVIDER=mock
EXPRESSION_PROVIDER=mock
CG_PROVIDER=mock

# Storage
UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs

# Optional API keys (future)
# BG_REMOVAL_API_KEY=
# IMAGE_GEN_API_KEY=
