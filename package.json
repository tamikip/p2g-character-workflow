{
  "name": "character-workflow-agent",
  "version": "1.3.5",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm run dev:web\"",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm --prefix server run start",
    "install:all": "npm install && npm --prefix server install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "vite": "^5.4.10"
  }
}
